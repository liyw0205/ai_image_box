<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AIImageBox" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/aib_primary_dark</item>
        <item name="colorPrimaryVariant">@color/aib_primary_dark</item>
        <item name="colorOnPrimary">@color/aib_on_primary</item>
        <item name="android:colorBackground">@color/aib_bg</item>
        <item name="colorSurface">@color/aib_surface</item>
        <item name="colorOnSurface">@color/aib_text</item>
        <item name="android:textColorPrimary">@color/aib_text</item>
        <item name="android:textColorSecondary">@color/aib_text_secondary</item>
        <item name="android:textColorHint">@color/aib_hint</item>
        <item name="android:statusBarColor">@color/aib_bg</item>
        <item name="android:navigationBarColor">@color/aib_surface</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.AIImageBox.AlertDialog</item>
        <item name="materialButtonStyle">@style/Widget.AIImageBox.Button</item>
        <item name="actionMenuTextColor">@color/aib_primary</item>
    </style>

    <style name="ThemeOverlay.AIImageBox.AlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorSurface">@color/aib_surface</item>
        <item name="colorOnSurface">@color/aib_text</item>
        <item name="android:textColorPrimary">@color/aib_text</item>
        <item name="android:textColorSecondary">@color/aib_text_secondary</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.AIImageBox.DialogButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.AIImageBox.DialogButton</item>
        <item name="buttonBarNeutralButtonStyle">@style/Widget.AIImageBox.DialogButton</item>
    </style>

    <style name="Widget.AIImageBox.DialogButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/aib_primary_dark</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.AIImageBox.Button" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">8dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.AIImageBox.Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">8dp</item>
        <item name="strokeColor">@color/aib_line</item>
        <item name="android:textColor">@color/aib_text</item>
        <item name="android:textAllCaps">false</item>
    </style>
</resources>
